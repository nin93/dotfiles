;: Settings :;
[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
;pseudo-transparency = true


;[global/wm]
;margin-top = 30
;margin-bottom = 0


;: Environment :;
[colors]
background  = #00000000
;background  = ${xrdb:background}
foreground  = ${xrdb:foreground}
darkblack   = ${xrdb:color0}
black       = ${xrdb:color8}
darkred     = ${xrdb:color1}
red         = ${xrdb:color9}
darkgreen   = ${xrdb:color2}
green       = ${xrdb:color10}
darkyellow  = ${xrdb:color3}
yellow      = ${xrdb:color11}
darkblue    = ${xrdb:color4}
blue        = ${xrdb:color12}
darkmagenta = ${xrdb:color5}
magenta     = ${xrdb:color13}
darkcyan    = ${xrdb:color6}
cyan        = ${xrdb:color14}
darkwhite   = ${xrdb:color7}
white       = ${xrdb:color15}

primary     = ${self.yellow}
secondary   = ${self.magenta}
alert       = ${self.magenta}


[fonts]
text  = CtrlD
icons = ProggyCleanTTSZ Nerd Font Mono:antialias=false:pixelsize=18


[icons]
app-term    = Óěē
app-browser = ÔČ©
app-mail    = Ôä∂
app-files   = ÔĀľ
app-music   = Ô≠Ķ
app-edit    = Ôáľ
app-chat    = Óąó
app-launch  = ÔĄĶ
app-calen   = Ôó≠
app-clock   = Ôźļ

mp-prev   = <
mp-next   = >
mp-play   = @
mp-stop   = ¬©
mp-pause  = #
;mp-random = ÔĀī
mp-cursor = ÔĄĆ
mp-fill   = Ô°≥
mp-empty  = Ô•Ą


;: Bars :;
[bar/generic]
height   = 35
offset-y = 4

fixed-center = true

background   = ${colors.background}
foreground   = ${colors.foreground}

padding-left  = 3
padding-right = 3

module-margin-left  = 1
module-margin-right = 1

line-size = 4

override-redirect = true

wm-restack  = bspwm
;wm-restack  = i3
;scroll-up   = i3wm-wsnext
;scroll-down = i3wm-wsprev

cursor-click  = pointer
cursor-scroll = ns-resize

font-0 = ${fonts.text}
font-1 = ${fonts.icons}


[bar/sys-monitor]
inherit = bar/generic
bottom = true

width    = 248
offset-x = 1663

modules-right = updates memory cpu


[bar/workspaces]
inherit = bar/generic
bottom = true

width    = 326
offset-x = 796

modules-center = bspwm
;modules-center = i3


[bar/music-player]
inherit = bar/generic
bottom = true

width    = 636
offset-x = 9

modules-left = mpd-controller mpd-song


[bar/app-title]
inherit = bar/generic

width    = 621
offset-x = 9

modules-left = xwindow


[bar/time]
inherit = bar/generic

width    = 242
offset-x = 839

modules-center = date clock


[bar/client-monitor]
inherit = bar/generic

width    = 412
offset-x = 1499

modules-right = capture alsa eth powermenu


;: Modules :;
[module/generic]
format = <label>

label-padding = 1

interval = 1.0


;: Window Managers :;
[module/i3]
type = internal/i3

enable-clic     = true
index-sort      = true
wrapping-scroll = false
strip-wsnumbers = true
fuzzy-match     = true
pin-workspaces  = false

ws-icon-0 = I;Óěē
ws-icon-1 = II;ÔČ©
ws-icon-2 = III;Ôä∂
ws-icon-3 = IV;
ws-icon-4 = V;ÔĀľ
ws-icon-5 = VI;Ôáľ
ws-icon-6 = VII;Óąó
ws-icon-7 = VIII;ÔĄĶ
ws-icon-8 = IX;
ws-icon-9 = X;Ô≠Ķ

format = <label-state> <label-mode>

label-mode-padding    = ${self.label-padding}
label-mode-foreground = ${colors.primary}
label-mode-background = ${colors.background}

label-focused            = %name%
label-focused-underline  = ${colors.primary}
label-focused-foreground = ${colors.primary}
label-focused-background = ${colors.background}
label-focused-padding    = ${self.label-padding}

label-unfocused         = %name%
label-unfocused-padding = ${self.label-padding}

label-visible            = %name%
label-visible-background = ${self.label-focused-background}
label-visible-underline  = ${self.label-focused-underline}
label-visible-padding    = ${self.label-focused-padding}

label-urgent             = %name%
label-urgent-underline   = ${colors.alert}
label-urgent-background  = ${colors.background}
label-urgent-foreground  = ${colors.alert}
label-urgent-padding     = ${self.label-padding}


[module/bspwm]
inherit = module/generic
type    = internal/bspwm

reverse-scroll = false
enable-scroll  = false

format = <label-state>

label-focused            = %name%
label-focused-underline  = ${colors.primary}
label-focused-foreground = ${colors.primary}
label-focused-background = ${colors.background}
label-focused-padding    = ${self.label-padding}

label-occupied         = %name%
label-occupied-padding = ${self.label-padding}

label-urgent            = %name%
label-urgent-underline  = ${colors.alert}
label-urgent-background = ${colors.background}
label-urgent-foreground = ${colors.alert}
label-urgent-padding    = ${self.label-padding}

label-empty             = %name%
label-empty-foreground  = ${colors.black}
label-empty-padding     = ${self.label-padding}


;: Modules :;
[module/mpd-controller]
inherit = module/generic
type    = internal/mpd

;icon-prev  = <
;icon-stop  = ¬©
;icon-play  = @
;icon-pause = #
;icon-next  = >

icon-prev  = %{T2}Ô¶™%{T-}
icon-stop  = ${icons.mp-stop}
icon-play  = %{T2}ÔĀč%{T-}
icon-pause = %{T2}Ô§ć%{T-}
icon-next  = %{T2}Ô¶ę%{T-}

format-offline =
format-online  = <icon-prev> <toggle> <icon-next>


[module/mpd-progress]
inherit = module/generic
type    = internal/mpd

format-offline =
format-online  = <label-time>

label-time = [%elapsed% ~ %total%]

bar-progress-width     = 13
bar-progress-indicator = ${icons.mp-cursor}
bar-progress-fill      = ${icons.mp-fill}
bar-progress-empty     = ${icons.mp-empty}


[module/mpd-song]
inherit = module/generic
type    = internal/mpd

format-offline = offline

format-online         = <label-song>
format-online-prefix  = %{T2}ÔÄĀ%{T-}

label-song         = %artist% ~ %title%
label-song-padding = ${self.label-padding}

label-song-maxlen   = 60
label-song-ellipsis = true


;: Time :;
[module/clock]
inherit = module/generic
type    = internal/date

format-prefix = %{T2}Ôźļ%{T-}

label = %time%

time = %H:%M


[module/date]
inherit = module/generic
type    = internal/date

format-prefix = %{T2}ÔČĪ%{T-}

label = %date%

date = %a %d %b %Y
date-alt = %d-%m-%Y


;: Utilities :;
[module/capture]
inherit = module/generic
type    = custom/script

;exec = scapture --screen

format-prefix = %{T2}ÔÄį%{T-}
format-prefix-foreground = ${colors.secondary}

format = <label>
label = %output%

label-padding = 1

label-foreground = ${colors.secondary}


;: XServer :;
[module/xwindow]
type  = internal/xwindow
label = %title:0:80:...%


;: System :;
[module/abs-sys]
interval = 1.0

format = <label>

label-padding = 1


[module/updates]
inherit = module/generic
type    = custom/script

exec = eix --installed --upgrade --only-names | wc -l
interval = 60.0

format-prefix = %{T2}Ôģģ%{T-}

format = <label>
label = %output%


[module/cpu]
inherit = module/generic
type    = internal/cpu

label = %percentage%%

format-prefix = "%{T2}Ô°ö%{T-}"


[module/memory]
inherit = module/generic
type    = internal/memory

label = %percentage_used%%

format-prefix = "%{T2}ÔÉ§%{T-}"


[module/eth]
inherit = module/generic
type    = internal/network

interface = enp1s0

interval = 5.0

format-connected-prefix = "%{T2}Ô™®%{T-}"
label-connected = %local_ip%

format-disconnected-prefix = "%{T2}Ô™©%{T-}"
label-disconnected = no network

label-connected-padding = ${self.label-padding}
label-disconnected-padding = ${self.label-padding}

[module/powermenu]
type = custom/menu

expand-right = false

format-spacing = 0

label-open = ‚Źľ
label-open-foreground = ${colors.secondary}

label-close = " ‚Źľ"
label-close-foreground = ${colors.secondary}

label-separator = " |"
label-separator-foreground = ${colors.foreground}

menu-0-0 = " reboot"
menu-0-0-exec = sudo reboot
menu-0-1 = " power off"
menu-0-1-exec = sudo poweroff


;: Audio :;
[module/pulseaudio]
type = internal/pulseaudio

format-volume = <label-volume> <ramp-volume>

label-volume = VOL %percentage%%
label-volume-foreground = ${colors.foreground}

label-muted = ūüĒá
label-muted-foreground = ${colors.foreground}


[module/alsa]
inherit = module/generic
type = internal/alsa

format-volume = <label-volume>
format-volume-prefix = "%{T2}Ô©Ņ%{T-}"

label-volume = %percentage%%
label-volume-padding = ${self.label-padding}

format-muted-prefix = "%{T2}ÔĪĚ%{T-}"
label-muted-padding = ${self.label-padding}

; vim:ft=dosini
