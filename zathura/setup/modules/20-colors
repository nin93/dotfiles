set default-bg "#1d1f21"
set default-fg "#b7bcba"

set recolor true
set recolor-lightcolor "#1d1f21"
set recolor-darkcolor  "#b7bcba"

# Completion
set completion-bg "#1d1f21"
set completion-fg "#b7bcba"

set completion-group-bg "#1d1f21"
set completion-group-fg "#a17eac"

set completion-highlight-bg "#e4b55e"
set completion-highlight-fg "#1d1f21"

# Search Highlight
set highlight-color        "#a17eac"
set highlight-active-color "#e4b55e"

# Notifications
set notification-bg "#1d1f21"
set notification-fg "#b7bcba"

set notification-error-bg "#1d1f21"
set notification-error-fg "#b84d51"

set notification-warning-bg "#1d1f21"
set notification-warning-fg "#e4b55e"

# Bars
set statusbar-bg "#1d1f21"
set statusbar-fg "#b7bcba"

set inputbar-bg "#1d1f21"
set inputbar-fg "#b3bf5a"

# Misc
set render-loading-bg "#1d1f21"
set render-loading-fg "#b7bcba"
